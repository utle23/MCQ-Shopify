{%- comment -%}
  ============================================================
  MCQ Supermarket — Full-width CTA banner
  A bold, image/overlay call-to-action band. Reusable on any
  page (About, collections, etc.). Supports background image
  and up to two buttons.
  ============================================================
{%- endcomment -%}

{{ 'mcq-custom.css' | asset_url | stylesheet_tag }}
<script src="{{ 'mcq-animations.js' | asset_url }}" defer></script>

{%- liquid assign s = section.settings -%}

<div
  class="mcq"
  style="--mcq-green:{{ s.brand_green }};--mcq-orange:{{ s.brand_orange }};--mcq-purple:{{ s.brand_purple }};"
>
  <section class="mcq-banner" style="min-height:{{ s.min_height }}px;">
    <div class="mcq-banner__media">
      {%- if s.image != blank -%}
        {{ s.image | image_url: width: 2000 | image_tag: loading: 'lazy', alt: s.heading }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'mcq-banner__ph' }}
      {%- endif -%}
    </div>
    <div class="mcq-banner__overlay"></div>
    <div class="mcq-banner__inner mcq-wrap mcq-reveal">
      {%- if s.eyebrow != blank -%}<span class="mcq-tag" style="background:{{ s.brand_orange }};color:#fff;">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h2>{{ s.heading }}</h2>{%- endif -%}
      {%- if s.text != blank -%}<p>{{ s.text }}</p>{%- endif -%}
      <div class="mcq-btn-row" style="justify-content:center;">
        {%- if s.btn1_label != blank -%}<a href="{{ s.btn1_link | default: '#' }}" class="mcq-btn mcq-btn--orange">{{ s.btn1_label }}</a>{%- endif -%}
        {%- if s.btn2_label != blank -%}<a href="{{ s.btn2_link | default: '#' }}" class="mcq-btn mcq-btn--outline">{{ s.btn2_label }}</a>{%- endif -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "MCQ CTA Banner",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Brand colours" },
    { "type": "color", "id": "brand_green", "label": "Green", "default": "#99C547" },
    { "type": "color", "id": "brand_orange", "label": "Orange", "default": "#F7A933" },
    { "type": "color", "id": "brand_purple", "label": "Purple", "default": "#8C3493" },

    { "type": "header", "content": "Content" },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "range", "id": "min_height", "label": "Height", "min": 280, "max": 640, "step": 20, "default": 420, "unit": "px" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Come visit us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Unbeatable value, fresh every day" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Five stores across Perth, open 7 days at most locations. We can't wait to welcome you in-store." },
    { "type": "text", "id": "btn1_label", "label": "Button 1 label", "default": "Find a Store" },
    { "type": "url", "id": "btn1_link", "label": "Button 1 link" },
    { "type": "text", "id": "btn2_label", "label": "Button 2 label", "default": "Shop Now" },
    { "type": "url", "id": "btn2_link", "label": "Button 2 link" }
  ],
  "presets": [
    { "name": "MCQ CTA Banner" }
  ]
}
{% endschema %}
