{%- comment -%}
  ============================================================
  MCQ Supermarket — FAQ (accordion)
  Native <details>/<summary> accordion — no JavaScript needed.
  Each Q&A is a block with a "category" field; questions are
  grouped by category automatically. Also outputs FAQPage
  JSON-LD structured data for rich results in Google.
  ============================================================
{%- endcomment -%}

{{ 'mcq-custom.css' | asset_url | stylesheet_tag }}
<script src="{{ 'mcq-animations.js' | asset_url }}" defer></script>

{%- liquid
  assign s = section.settings
  assign faq_blocks = section.blocks | where: 'type', 'faq'

  comment
  Build an ordered list of unique category names
  endcomment
  assign cat_list = '|~|'
  for b in faq_blocks
    assign c = b.settings.category | default: 'General'
    assign c_key = '|~|' | append: c | append: '|~|'
    unless cat_list contains c_key
      assign cat_list = cat_list | append: c | append: '|~|'
    endunless
  endfor
  assign cats = cat_list | split: '|~|'
-%}

<div
  class="mcq mcq-faq-wrap"
  style="--mcq-green:{{ s.brand_green }};--mcq-orange:{{ s.brand_orange }};--mcq-purple:{{ s.brand_purple }};"
>
  <section class="mcq-section">
    <div class="mcq-wrap">
      <div class="mcq-head mcq-reveal">
        <span class="mcq-tag">{{ s.eyebrow }}</span>
        <h2>{{ s.heading }}</h2>
        {%- if s.intro != blank -%}<p>{{ s.intro }}</p>{%- endif -%}
      </div>

      <div class="mcq-faq">
        {%- for cat in cats -%}
          {%- if cat != blank -%}
            <div class="mcq-faq__cat mcq-reveal">
              <h3>{{ cat }}</h3>
              {%- for block in faq_blocks -%}
                {%- assign bcat = block.settings.category | default: 'General' -%}
                {%- if bcat == cat -%}
                  <details class="mcq-acc" {{ block.shopify_attributes }}{% if block.settings.open %} open{% endif %}>
                    <summary>{{ block.settings.question }}</summary>
                    <div class="mcq-acc__body">{{ block.settings.answer }}</div>
                  </details>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if s.contact_heading != blank -%}
        <div class="mcq-empty" style="border-style:solid;border-color:#eee;background:#FAF8F2;margin-top:20px;">
          <p style="font-weight:700;color:var(--mcq-dark);font-size:16px;margin-bottom:6px;">{{ s.contact_heading }}</p>
          {%- if s.contact_text != blank -%}<p>{{ s.contact_text }}</p>{%- endif -%}
          {%- if s.phone != blank -%}<p style="margin-top:10px;"><a href="tel:{{ s.phone | remove: ' ' }}" class="mcq-btn mcq-btn--purple">📞 {{ s.phone }}</a></p>{%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </section>
</div>

{%- comment -%} SEO: FAQPage structured data {%- endcomment -%}
{%- if faq_blocks.size > 0 -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for block in faq_blocks -%}
        {
          "@type": "Question",
          "name": {{ block.settings.question | strip_html | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | json }}
          }
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "MCQ FAQ",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Brand colours" },
    { "type": "color", "id": "brand_green", "label": "Green", "default": "#99C547" },
    { "type": "color", "id": "brand_orange", "label": "Orange", "default": "#F7A933" },
    { "type": "color", "id": "brand_purple", "label": "Purple", "default": "#8C3493" },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Help centre" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Everything you need to know about shopping, rewards and wholesale at MCQ Supermarket." },

    { "type": "header", "content": "Still need help? card" },
    { "type": "text", "id": "contact_heading", "label": "Heading", "default": "Still have a question?" },
    { "type": "textarea", "id": "contact_text", "label": "Text", "default": "Our friendly team is here to help — call us any time during store hours." },
    { "type": "text", "id": "phone", "label": "Phone", "default": "08 9248 5623" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Q & A",
      "settings": [
        { "type": "text", "id": "category", "label": "Category", "default": "General", "info": "Questions with the same category are grouped together." },
        { "type": "text", "id": "question", "label": "Question", "default": "Your question here?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Your answer here.</p>" },
        { "type": "checkbox", "id": "open", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "MCQ FAQ",
      "blocks": [
        { "type": "faq", "settings": { "category": "MCQ Rewards", "question": "How do I sign up for MCQ Rewards?", "answer": "<p>You can join via the Go Rewards app, or simply give your details at the checkout of any MCQ store. It's free to join.</p>" } },
        { "type": "faq", "settings": { "category": "MCQ Rewards", "question": "Where can I redeem my points?", "answer": "<p>Points can be redeemed as a discount directly off your bill at any MCQ Supermarket store in Western Australia.</p>" } },
        { "type": "faq", "settings": { "category": "Wholesale Services", "question": "Do you offer wholesale prices for restaurants and businesses?", "answer": "<p>Yes — we offer highly competitive wholesale pricing. Please fill in our Wholesale Inquiry form or contact our Malaga branch for details.</p>" } },
        { "type": "faq", "settings": { "category": "Wholesale Services", "question": "Is there a minimum order for wholesale?", "answer": "<p>It depends on the product. Get in touch via the Wholesale Inquiry form and our team will walk you through the current catalogue.</p>" } },
        { "type": "faq", "settings": { "category": "Shopping & Payment", "question": "Can I order online and get delivery?", "answer": "<p>Yes — you can now shop online through our Shopify store. In-store shopping remains available at all five WA locations.</p>" } },
        { "type": "faq", "settings": { "category": "Shopping & Payment", "question": "What payment methods do you accept?", "answer": "<p>We accept cash, EFTPOS, Visa, Mastercard and popular Australian digital wallets.</p>" } },
        { "type": "faq", "settings": { "category": "Products & Fresh Produce", "question": "Is your fruit and veg fresh every day?", "answer": "<p>Absolutely. MCQ sources fresh produce from Western Australian farms every morning to guarantee the best quality.</p>" } },
        { "type": "faq", "settings": { "category": "Products & Fresh Produce", "question": "Do you stock imported Asian products?", "answer": "<p>Yes — MCQ specialises in Asian and international groceries, with a huge range from Vietnam, Thailand, China, Malaysia and beyond.</p>" } }
      ]
    }
  ]
}
{% endschema %}
