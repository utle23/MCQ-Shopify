{%- comment -%}
  ============================================================
  MCQ Supermarket — About Us
  History, vision and values. Fully editable; milestones and
  values are section blocks.
  ============================================================
{%- endcomment -%}

{{ 'mcq-custom.css' | asset_url | stylesheet_tag }}

{%- liquid assign s = section.settings -%}

<div
  class="mcq mcq-about"
  style="--mcq-green:{{ s.brand_green }};--mcq-orange:{{ s.brand_orange }};--mcq-purple:{{ s.brand_purple }};"
>

  {%- comment -%} ---------- ABOUT HERO ---------- {%- endcomment -%}
  <section class="mcq-hero" style="min-height:460px;">
    <div class="mcq-hero__media">
      {%- if s.hero_image != blank -%}
        {{ s.hero_image | image_url: width: 2000 | image_tag: loading: 'eager', alt: s.heading }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'mcq-hero__ph' }}
      {%- endif -%}
    </div>
    <div class="mcq-hero__overlay"></div>
    <div class="mcq-hero__inner mcq-wrap">
      {%- if s.eyebrow != blank -%}<span class="mcq-tag">{{ s.eyebrow }}</span>{%- endif -%}
      <h1>{{ s.heading }}</h1>
      {%- if s.subheading != blank -%}<p class="mcq-hero__sub">{{ s.subheading }}</p>{%- endif -%}
    </div>
  </section>

  {%- comment -%} ---------- STORY SPLIT ---------- {%- endcomment -%}
  {%- if s.story_heading != blank -%}
    <section class="mcq-section">
      <div class="mcq-wrap mcq-split">
        <div>
          <span class="mcq-tag" style="background:var(--mcq-cream);color:#8a5c00;">{{ s.story_eyebrow }}</span>
          <h2>{{ s.story_heading }}</h2>
          <div class="mcq-rte">{{ s.story_text }}</div>
        </div>
        <div class="mcq-split__media">
          {%- if s.story_image != blank -%}
            {{ s.story_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: s.story_heading }}
          {%- else -%}
            <span class="mcq-card__ph"></span>
          {%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ---------- VALUES ---------- {%- endcomment -%}
  {%- assign value_blocks = section.blocks | where: 'type', 'value' -%}
  {%- if value_blocks.size > 0 -%}
    <section class="mcq-section mcq-section--alt">
      <div class="mcq-wrap">
        <div class="mcq-head">
          <span class="mcq-tag">{{ s.values_eyebrow }}</span>
          <h2>{{ s.values_heading }}</h2>
          {%- if s.values_text != blank -%}<p>{{ s.values_text }}</p>{%- endif -%}
        </div>
        <div class="mcq-values">
          {%- for block in value_blocks -%}
            <div class="mcq-value" {{ block.shopify_attributes }}>
              <div class="mcq-value__icon">{{ block.settings.emoji | default: '✅' }}</div>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ---------- TIMELINE ---------- {%- endcomment -%}
  {%- assign milestone_blocks = section.blocks | where: 'type', 'milestone' -%}
  {%- if milestone_blocks.size > 0 -%}
    <section class="mcq-section">
      <div class="mcq-wrap">
        <div class="mcq-head">
          <span class="mcq-tag">{{ s.timeline_eyebrow }}</span>
          <h2>{{ s.timeline_heading }}</h2>
        </div>
        <div class="mcq-timeline">
          {%- for block in milestone_blocks -%}
            <div class="mcq-milestone" {{ block.shopify_attributes }}>
              <div class="mcq-year">{{ block.settings.year }}</div>
              <div>
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.text }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ---------- CTA ---------- {%- endcomment -%}
  {%- if s.cta_heading != blank -%}
    <section class="mcq-section mcq-rewards">
      <div class="mcq-wrap" style="text-align:center;">
        <h2 style="font-size:clamp(24px,4vw,34px);margin-bottom:12px;">{{ s.cta_heading }}</h2>
        {%- if s.cta_text != blank -%}<p style="color:#e9d9eb;max-width:560px;margin:0 auto 26px;">{{ s.cta_text }}</p>{%- endif -%}
        <div class="mcq-btn-row" style="justify-content:center;">
          {%- if s.cta_btn1_label != blank -%}<a href="{{ s.cta_btn1_link | default: '#' }}" class="mcq-btn mcq-btn--orange">{{ s.cta_btn1_label }}</a>{%- endif -%}
          {%- if s.cta_btn2_label != blank -%}<a href="{{ s.cta_btn2_link | default: '#' }}" class="mcq-btn mcq-btn--outline">{{ s.cta_btn2_label }}</a>{%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "MCQ About",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Brand colours" },
    { "type": "color", "id": "brand_green", "label": "Green", "default": "#99C547" },
    { "type": "color", "id": "brand_orange", "label": "Orange", "default": "#F7A933" },
    { "type": "color", "id": "brand_purple", "label": "Purple", "default": "#8C3493" },

    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Bringing Western Australia unbeatable value since day one" },
    { "type": "textarea", "id": "subheading", "label": "Sub-heading", "default": "MCQ Supermarket — your local home for fresh produce and international groceries across Perth, WA." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },

    { "type": "header", "content": "Story" },
    { "type": "text", "id": "story_eyebrow", "label": "Eyebrow", "default": "Who we are" },
    { "type": "text", "id": "story_heading", "label": "Heading", "default": "A family-run supermarket built on fresh produce & real value" },
    { "type": "richtext", "id": "story_text", "label": "Text", "default": "<p>MCQ Supermarket has proudly served Western Australian families for years, growing from a single local store into a trusted network of supermarkets across Perth.</p><p>We specialise in farm-fresh produce and a huge range of international groceries — sourced through strong global supplier relationships so we can pass real savings on to our customers. In 2025 we launched a brand-new digital experience to make shopping with MCQ easier than ever.</p>" },
    { "type": "image_picker", "id": "story_image", "label": "Story image" },

    { "type": "header", "content": "Values heading" },
    { "type": "text", "id": "values_eyebrow", "label": "Eyebrow", "default": "What we stand for" },
    { "type": "text", "id": "values_heading", "label": "Heading", "default": "Our promise to you" },
    { "type": "text", "id": "values_text", "label": "Text", "default": "The values that have guided MCQ from the very beginning." },

    { "type": "header", "content": "Timeline heading" },
    { "type": "text", "id": "timeline_eyebrow", "label": "Eyebrow", "default": "Our journey" },
    { "type": "text", "id": "timeline_heading", "label": "Heading", "default": "Milestones" },

    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "cta_heading", "label": "Heading", "default": "Come and see the difference in-store" },
    { "type": "textarea", "id": "cta_text", "label": "Text", "default": "Five locations across Perth, open 7 days at most stores. We can't wait to welcome you." },
    { "type": "text", "id": "cta_btn1_label", "label": "Button 1 label", "default": "Find a Store" },
    { "type": "url", "id": "cta_btn1_link", "label": "Button 1 link" },
    { "type": "text", "id": "cta_btn2_label", "label": "Button 2 label", "default": "Wholesale Inquiry" },
    { "type": "url", "id": "cta_btn2_link", "label": "Button 2 link" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        { "type": "text", "id": "emoji", "label": "Emoji", "default": "🥬" },
        { "type": "text", "id": "title", "label": "Title", "default": "Fresh, every day" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Produce delivered fresh each morning for the best quality." }
      ]
    },
    {
      "type": "milestone",
      "name": "Milestone",
      "settings": [
        { "type": "text", "id": "year", "label": "Year", "default": "2020" },
        { "type": "text", "id": "title", "label": "Title", "default": "Growing across Perth" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Operating strongly across multiple Western Australian locations." }
      ]
    }
  ],
  "presets": [
    {
      "name": "MCQ About",
      "blocks": [
        { "type": "value", "settings": { "emoji": "🥬", "title": "Fresh, every day", "text": "Farm-fresh produce delivered each morning for the best quality." } },
        { "type": "value", "settings": { "emoji": "🌏", "title": "A world of flavour", "text": "A huge range of international groceries from across Asia and beyond." } },
        { "type": "value", "settings": { "emoji": "💰", "title": "Unbeatable value", "text": "Strong supplier relationships mean real savings passed on to you." } },
        { "type": "milestone", "settings": { "year": "Pre-2020", "title": "Serving the community", "text": "MCQ builds a loyal following across Perth for fresh produce and international groceries." } },
        { "type": "milestone", "settings": { "year": "2020", "title": "A growing network", "text": "Operating strongly across multiple Western Australian locations — Malaga, Morley, Armadale, Subiaco and Mirrabooka." } },
        { "type": "milestone", "settings": { "year": "2025", "title": "Going digital", "text": "MCQ launches a brand-new digital experience powered by Shopify and LS Retail." } }
      ]
    }
  ]
}
{% endschema %}
